# Environment Variables for RAG Application
# Copy this file to .env and fill in your actual values
# 
# SECURITY WARNING: Never commit .env files to version control!
# Keep your API keys and passwords secure and rotate them regularly.

# ===================================================================
# REQUIRED CONFIGURATION - Application will fail without these
# ===================================================================

# OpenAI Configuration (Required)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# TimescaleDB Connection (Required)
# Format: postgresql://username:password@host:port/database
TIMESCALE_SERVICE_URL=postgresql://postgres:your_secure_password@localhost:5432/postgres

# ===================================================================
# DATABASE CONFIGURATION
# ===================================================================

# PostgreSQL Password (used by Docker Compose)
# IMPORTANT: Use a strong password in production!
POSTGRES_PASSWORD=your_secure_password_here

# ===================================================================
# OPTIONAL CONFIGURATION
# ===================================================================

# API Authentication (comma-separated keys for multiple clients)
# Generate secure random keys: openssl rand -hex 32
RAG_API_KEYS=your_secure_api_key_here,another_key_for_different_client

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Data Directory (where PDFs are stored)
DATA_DIR=./data/documents

# ===================================================================
# PRODUCTION SECURITY NOTES
# ===================================================================
# 1. Use environment-specific .env files (.env.prod, .env.staging)
# 2. Consider using secret management services (AWS Secrets Manager, etc.)
# 3. Regularly rotate API keys and passwords
# 4. Use strong passwords (minimum 16 characters with mixed case, numbers, symbols)
# 5. Enable database SSL in production
# 6. Limit database user permissions to minimum required